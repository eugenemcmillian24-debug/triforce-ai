{
  "name": "triforce-ai",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "deploy": "turbo deploy",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "wrangler d1 execute triforce-db --file=schema.sql",
    "db:seed": "bun run packages/ai-core/scripts/seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2"
  },
  "packageManager": "bun@1.1.42",
  "engines": {
    "node": ">=20.0.0"
  }
}
