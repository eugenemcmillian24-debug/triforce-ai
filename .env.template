# ========================================
# TriForce AI — Environment Variables Template
# ========================================
# Copy this file to apps/web/.env.local
# Get your FREE API keys from the URLs below
# ========================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MINIMUM REQUIRED (Start with these)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Groq — Ultra-fast inference (REQUIRED)
# Free: 500K tokens/week | Get: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini — Massive 1M context (RECOMMENDED)
# Free: ~1M tokens/day | Get: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza_your_google_api_key_here

# Cerebras — Fast reasoning (RECOMMENDED)
# Free: 1M tokens/week | Get: https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk_your_cerebras_api_key_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ADDITIONAL FREE PROVIDERS (Optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenRouter — Access to 100+ models
# Free tier varies | Get: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# DeepSeek — Reasoning specialist
# Free: 1M tokens/month | Get: https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# Mistral AI — Code generation
# Free: 1M tokens/month | Get: https://console.mistral.ai/api-keys  
MISTRAL_API_KEY=your_mistral_api_key_here

# HuggingFace — Open source models
# Free: 30K tokens/month | Get: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# NVIDIA NIM — AGI-grade models
# Free: 40 req/min | Get: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your_nvidia_key_here

# Cloudflare AI — Edge inference
# Free: 10K requests/day | Get: https://dash.cloudflare.com
CLOUDFLARE_API_TOKEN=your_cloudflare_token_here

# SambaNova — High-performance models
# Free tier available | Get: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=your_sambanova_key_here

# GitHub Models — Microsoft models
# Free: 15 req/min | Use your GitHub token
GITHUB_TOKEN=ghp_your_github_token_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AUTHENTICATION (For GitHub OAuth)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# GitHub OAuth App
# Create: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# NextAuth secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_32_char_secret_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE (Cloudflare D1)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Cloudflare credentials
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_DATABASE_ID=your_database_id_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL ENHANCEMENTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Sentry error tracking (optional)
SENTRY_DSN=your_sentry_dsn_here

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
